//@version=5
strategy("Long Only Same-Day 3 Percent Strategy", overlay=true, pyramiding=0, initial_capital=100000, default_qty_type=strategy.percent_of_equity, default_qty_value=10, commission_type=strategy.commission.percent, commission_value=0.05, process_orders_on_close=true)

groupSession = "Session"
groupEntry = "Entry"
groupTrend = "Trend Filter"
groupRisk = "Risk"
groupBacktest = "Backtest"
groupDisplay = "Display"

tradeSession = input.session("0915-1515", "Trading session", group=groupSession)
lastEntryHour = input.int(14, "Last entry hour", minval=0, maxval=23, group=groupSession)
lastEntryMinute = input.int(45, "Last entry minute", minval=0, maxval=59, group=groupSession)
forceExitHour = input.int(15, "Force exit hour", minval=0, maxval=23, group=groupSession)
forceExitMinute = input.int(15, "Force exit minute", minval=0, maxval=59, group=groupSession)
oneTradePerDay = input.bool(true, "One trade per day", group=groupSession)

entryMode = input.string("Breakout Above VWAP", "Entry mode", options=["Breakout Above VWAP", "EMA Pullback", "Breakout Or Pullback"], group=groupEntry)
fastEmaLength = input.int(9, "Fast EMA", minval=2, group=groupEntry)
slowEmaLength = input.int(20, "Slow EMA", minval=5, group=groupEntry)
breakoutLookback = input.int(10, "Breakout lookback", minval=2, group=groupEntry)
volumeLength = input.int(20, "Volume average length", minval=5, group=groupEntry)
minRelativeVolume = input.float(1.0, "Min relative volume", minval=0.1, step=0.1, group=groupEntry)

useTrendFilter = input.bool(true, "Use 1H and 4H trend filter", group=groupTrend)
trendTf1 = input.timeframe("60", "Trend timeframe 1", group=groupTrend)
trendTf2 = input.timeframe("240", "Trend timeframe 2", group=groupTrend)
trendEmaLength = input.int(20, "Trend EMA length", minval=5, group=groupTrend)

takeProfitPct = input.float(3.0, "Take profit %", minval=0.1, step=0.1, group=groupRisk)
stopLossPct = input.float(3.0, "Stop loss %", minval=0.1, step=0.1, group=groupRisk)

startDate = input.time(1704067200000, "Backtest start", group=groupBacktest)
endDate = input.time(1830297540000, "Backtest end", group=groupBacktest)

showSignals = input.bool(true, "Show entry and exit markers", group=groupDisplay)
showTable = input.bool(true, "Show status table", group=groupDisplay)

inDateRange = time >= startDate and time <= endDate
inSession = not na(time(timeframe.period, tradeSession))
newSession = inSession and not inSession[1]

currentMinutes = hour * 60 + minute
lastEntryMinutes = lastEntryHour * 60 + lastEntryMinute
forceExitMinutes = forceExitHour * 60 + forceExitMinute
beforeLastEntry = currentMinutes <= lastEntryMinutes
afterForceExit = currentMinutes >= forceExitMinutes

fastEma = ta.ema(close, fastEmaLength)
slowEma = ta.ema(close, slowEmaLength)
sessionVwap = ta.vwap(hlc3)
avgVolume = ta.sma(volume, volumeLength)
relativeVolume = avgVolume > 0 ? volume / avgVolume : 0.0
recentHigh = ta.highest(high, breakoutLookback)[1]

htfClose1 = request.security(syminfo.tickerid, trendTf1, close, lookahead=barmerge.lookahead_off)
htfEma1 = request.security(syminfo.tickerid, trendTf1, ta.ema(close, trendEmaLength), lookahead=barmerge.lookahead_off)
htfClose2 = request.security(syminfo.tickerid, trendTf2, close, lookahead=barmerge.lookahead_off)
htfEma2 = request.security(syminfo.tickerid, trendTf2, ta.ema(close, trendEmaLength), lookahead=barmerge.lookahead_off)

trendOk = not useTrendFilter or ((htfClose1 > htfEma1 and htfEma1 >= htfEma1[1]) and (htfClose2 > htfEma2 and htfEma2 >= htfEma2[1]))
intradayTrendOk = close > fastEma and fastEma > slowEma and close > sessionVwap
volumeOk = relativeVolume >= minRelativeVolume

breakoutEntry = close > recentHigh and close[1] <= recentHigh and close > sessionVwap and intradayTrendOk and volumeOk
pullbackEntry = low <= fastEma and close > fastEma and fastEma > slowEma and close > sessionVwap and volumeOk

entrySignal = entryMode == "Breakout Above VWAP" ? breakoutEntry : entryMode == "EMA Pullback" ? pullbackEntry : (breakoutEntry or pullbackEntry)

var int tradesToday = 0
var float activeEntryPrice = na

if newSession
    tradesToday := 0
    activeEntryPrice := na

canEnter = inDateRange and inSession and beforeLastEntry and strategy.position_size == 0 and trendOk and (not oneTradePerDay or tradesToday == 0)

if canEnter and entrySignal
    strategy.entry("Long", strategy.long, comment="Long intraday")
    tradesToday += 1

if strategy.position_size > 0 and na(activeEntryPrice)
    activeEntryPrice := strategy.position_avg_price

if strategy.position_size > 0 and not na(activeEntryPrice)
    takeProfitPrice = activeEntryPrice * (1 + takeProfitPct / 100.0)
    stopLossPrice = activeEntryPrice * (1 - stopLossPct / 100.0)
    strategy.exit("Long exit", "Long", limit=takeProfitPrice, stop=stopLossPrice, comment="3 percent exit")

if inSession and afterForceExit and strategy.position_size > 0
    strategy.close("Long", comment="End of day exit")

if strategy.position_size == 0
    activeEntryPrice := na

plot(fastEma, "Fast EMA", color=color.new(color.green, 0))
plot(slowEma, "Slow EMA", color=color.new(color.orange, 0))
plot(sessionVwap, "VWAP", color=color.new(color.blue, 0))

entryMarker = showSignals and canEnter and entrySignal
exitMarker = showSignals and strategy.position_size == 0 and strategy.position_size[1] > 0

plotshape(entryMarker, title="Long Entry", style=shape.labelup, location=location.belowbar, color=color.new(color.green, 0), textcolor=color.white, text="BUY")
plotshape(exitMarker, title="Exit", style=shape.labeldown, location=location.abovebar, color=color.new(color.red, 0), textcolor=color.white, text="EXIT")

var table statusTable = table.new(position.top_right, 2, 7, border_width=1)
if barstate.islast and showTable
    targetText = na(activeEntryPrice) ? "-" : str.tostring(activeEntryPrice * (1 + takeProfitPct / 100.0), format.mintick)
    stopText = na(activeEntryPrice) ? "-" : str.tostring(activeEntryPrice * (1 - stopLossPct / 100.0), format.mintick)
    table.cell(statusTable, 0, 0, "Same-Day Long", bgcolor=color.new(color.blue, 70), text_color=color.white)
    table.cell(statusTable, 1, 0, syminfo.ticker, bgcolor=color.new(color.blue, 70), text_color=color.white)
    table.cell(statusTable, 0, 1, "Trend ok")
    table.cell(statusTable, 1, 1, trendOk ? "Yes" : "No")
    table.cell(statusTable, 0, 2, "Entry mode")
    table.cell(statusTable, 1, 2, entryMode)
    table.cell(statusTable, 0, 3, "Rel volume")
    table.cell(statusTable, 1, 3, str.tostring(relativeVolume, "#.##"))
    table.cell(statusTable, 0, 4, "Entry price")
    table.cell(statusTable, 1, 4, na(activeEntryPrice) ? "-" : str.tostring(activeEntryPrice, format.mintick))
    table.cell(statusTable, 0, 5, "Target / Stop")
    table.cell(statusTable, 1, 5, targetText + " / " + stopText)
    table.cell(statusTable, 0, 6, "Trades today")
    table.cell(statusTable, 1, 6, str.tostring(tradesToday))
